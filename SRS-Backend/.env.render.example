APP_NAME=SRS-ERP
APP_ENV=production
APP_KEY=                        # توليد تلقائي من Render — اتركه فاضي
APP_DEBUG=false
APP_URL=https://YOUR-SERVICE.onrender.com

LOG_CHANNEL=stderr
LOG_LEVEL=error

# ── TiDB Cloud (من صفحة Connect في TiDB dashboard) ─────────────────
DB_CONNECTION=mysql
DB_HOST=gateway01.eu-central-1.prod.aws.tidbcloud.com   # غيّره لـ host بتاعك
DB_PORT=4000
DB_DATABASE=srs
DB_USERNAME=YOUR_TIDB_USERNAME
DB_PASSWORD=YOUR_TIDB_PASSWORD
MYSQL_ATTR_SSL_CA=/etc/ssl/certs/ca-certificates.crt

# ── Session / Cache ──────────────────────────────────────────────────
SESSION_DRIVER=cookie
SESSION_LIFETIME=120
CACHE_DRIVER=array
QUEUE_CONNECTION=sync

# ── Mail (اختياري) ───────────────────────────────────────────────────
MAIL_MAILER=log
