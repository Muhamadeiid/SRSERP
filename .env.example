# SRS ERP local/offline deployment notes
# Copy backend values to: SRS-Backend/.env
# Copy frontend values to: Frontend - Copy/.env

# Backend
APP_NAME=SRS
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_URL=http://SERVER-IP:8000

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=srs
DB_USERNAME=root
DB_PASSWORD=

CACHE_DRIVER=file
QUEUE_CONNECTION=sync
SESSION_DRIVER=file
SESSION_LIFETIME=120

# Comma-separated browser origins allowed to call the API.
FRONTEND_ORIGINS=http://SERVER-IP:5175,http://localhost:5175,http://127.0.0.1:5175

# Frontend
VITE_API_URL=http://SERVER-IP:8000/api
VITE_API_BASE=http://SERVER-IP:8000/api
