# Optional Docker settings.
# Copy this file to `.env` before running docker compose if you want custom values.
# The project also runs without copying it, using the defaults below.

APP_NAME=SRS
APP_ENV=production
APP_DEBUG=false
APP_URL=http://localhost:8000

MYSQL_DATABASE=srs
MYSQL_ROOT_PASSWORD=srs_root_password
MYSQL_PORT=3307

API_PORT=8000
FRONTEND_PORT=5175
FRONTEND_ORIGINS=http://localhost:5175,http://127.0.0.1:5175

# In Docker the frontend uses same-origin /api through Nginx.
VITE_API_URL=/api
VITE_API_BASE=/api
